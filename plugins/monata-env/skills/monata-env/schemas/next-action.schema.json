{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "monata-env next action",
  "type": "object",
  "required": ["id", "title", "requires_user_input", "prompt"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "requires_user_input": {
      "type": "boolean"
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string"
    },
    "evidence": {
      "type": "object"
    },
    "decision": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "default": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "requires_user_input", "effect"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "requires_user_input": {
                "type": "boolean"
              },
              "effect": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
